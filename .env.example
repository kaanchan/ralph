# Copy to .env and fill in values. Never commit .env.

# Google Gemini free tier -- https://aistudio.google.com/app/apikey
# 1,500 req/day, 60 req/min on Gemini 2.0 Flash
GEMINI_API_KEY=your-gemini-key-here

# LangSmith tracing (non-negotiable for debugging LangGraph)
# Sign up free at https://smith.langchain.com -> Settings -> API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ralph
LANGCHAIN_API_KEY=your-langsmith-key-here
